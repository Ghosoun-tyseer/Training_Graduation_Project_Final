@model EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
    var initials = string.Join("", (Model.FullName ?? "?").Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString() : "")).ToUpper();
}

<div class="page-header"><div class="page-title">Edit Profile</div></div>

<form asp-action="EditProfile" asp-controller="Account" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />
    <input type="hidden" asp-for="Role" />
    <input type="hidden" asp-for="CurrentAvatar" />

    <div class="profile-hero">
        @if (!string.IsNullOrEmpty(Model.CurrentAvatar))
        {
            <img src="@Model.CurrentAvatar" alt="avatar" class="profile-av avatar-img" id="av-preview-img"
                 style="object-fit:cover;" />
        }
        else
        {
            <div class="profile-av" id="av-preview-txt">@initials</div>
        }
        <div style="flex:1;">
            <div class="profile-name" id="ep-name">@Model.FullName</div>
            <span class="badge @(Model.Role == "admin" ? "b-admin" : Model.Role == "engineer" ? "b-engineer" : "b-staff")"
                  style="margin-top:6px;display:inline-flex;">
                @(Model.Role == "admin" ? "Administrator" : Model.Role == "engineer" ? "Engineer" : "Medical Staff")
            </span>
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger" style="margin-bottom:16px;">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@err.ErrorMessage</div>
            }
        </div>
    }

    <div class="info-section">
        <div class="info-section-ttl">Personal Information</div>
        <div class="info-2col">
            <div class="form-group">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control"
                       oninput="document.getElementById('ep-name').textContent=this.value||'Name'" />
                <span asp-validation-for="FullName" class="val-msg"></span>
            </div>
            <div class="form-group">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" />
                <span asp-validation-for="Username" class="val-msg"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="val-msg"></span>
            </div>
            <div class="form-group">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="val-msg"></span>
            </div>
        </div>
    </div>

    @if (Model.Role == "engineer" || Model.Role == "staff")

    {
        <div class="info-section">
            <div class="info-section-ttl">Work Information</div>
            <div class="info-2col">
                <div class="form-group">
                    <label asp-for="JobTitle" class="form-label"></label>
                    <input asp-for="JobTitle" class="form-control" placeholder="Doctor / Nurse / Engineer..." />
                </div>

              
                @if (Model.Role == "staff")

                {

                    var departments = ViewBag.Departments as IEnumerable < SMEMS.Models.Department >


                    ?? Enumerable.Empty <SMEMS.Models.Department > ();
                    <div class="form-group">
                        <label asp-for="DepartmentId" class="form-label">Department</label>
                        <select asp-for="DepartmentId" class="form-control">
                            <option value="">Select Department</option>
                            @foreach (var d in departments)
                            {
                                <option value="@d.DepartmentId">@d.Name</option>
                            }
                        </select>
                    </div>
                }
            </div>
        </div>
    }

    <div class="info-section">
        <div class="info-section-ttl">Profile Photo</div>
        <div class="form-group" style="max-width:400px;">
            <label asp-for="AvatarFile" class="form-label">Upload New Photo</label>
            <input asp-for="AvatarFile" type="file" class="form-control" accept="image/*"
                   onchange="previewAvatar(this)" />
            <small style="color:var(--text-3);font-size:12px;">Max 2MB – JPG, PNG or WebP. Leave empty to keep current.</small>
        </div>
    </div>

    <div class="info-section">
        <div class="info-section-ttl">Security</div>
        <a asp-action="ChangePassword" asp-controller="Account" class="btn btn-primary">🔒 Change Password</a>
    </div>

    <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:4px;">
        <a asp-action="Profile" asp-controller="Account" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        function previewAvatar(input) {
            if (!input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function(e) {
                var img = document.getElementById('av-preview-img');
                var txt = document.getElementById('av-preview-txt');
                if (img) { img.src = e.target.result; }
                else if (txt) {
                    txt.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" />';
                }
            };
            reader.readAsDataURL(input.files[0]);
        }
    </script>
}
