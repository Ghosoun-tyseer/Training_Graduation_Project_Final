@* ─── ChangePassword ─── *@
@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="page-header"><div class="page-title">Change Password</div></div>

<div class="card" style="max-width:500px;">
    <form asp-action="ChangePassword" asp-controller="Account" method="post">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" style="margin-bottom:16px;">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <div class="form-group">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <input asp-for="CurrentPassword" class="form-control" placeholder="Current password" />
            <span asp-validation-for="CurrentPassword" class="val-msg"></span>
        </div>
        <div class="form-group">
            <label asp-for="NewPassword" class="form-label"></label>
            <input asp-for="NewPassword" class="form-control" placeholder="New password (min 6 chars)" />
            <span asp-validation-for="NewPassword" class="val-msg"></span>
        </div>
        <div class="form-group">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm new password" />
            <span asp-validation-for="ConfirmPassword" class="val-msg"></span>
        </div>

        <div style="display:flex;gap:10px;margin-top:8px;">
            <a asp-action="Profile" asp-controller="Account" class="btn btn-outline">Cancel</a>
            <button type="submit" class="btn btn-primary">Update Password</button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
