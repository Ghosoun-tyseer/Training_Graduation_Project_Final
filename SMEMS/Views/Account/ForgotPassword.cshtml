@model ForgotPasswordViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Reset Password";
}

<div class="login-page">
    <div class="login-brand">
        <div class="login-logo" style="width:56px;height:56px;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
        </div>
        <h1>SMEMS</h1>
        <p>Smart Medical Equipment Management System</p>
    </div>

    <div class="login-card">
        <h2 style="font-size:20px;margin-bottom:8px;">Reset Password</h2>
        <p style="font-size:13px;color:var(--text-3);margin-bottom:24px;">
            Enter your work email and we'll send you a reset link.
        </p>

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="name@hospital.com" />
                <span asp-validation-for="Email" class="val-msg"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full" style="margin-bottom:16px;">
                Send Reset Link
            </button>
        </form>

        <div style="text-align:center;font-size:13px;color:var(--text-3);margin-bottom:12px;">
            Forgot your email?
            <span style="color:var(--danger);font-weight:500;cursor:pointer;">Contact IT Support</span>
        </div>

        <div style="text-align:center;">
            <a asp-action="Login" asp-controller="Account"
               style="font-size:13px;color:var(--primary);text-decoration:none;">← Back to Login</a>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
