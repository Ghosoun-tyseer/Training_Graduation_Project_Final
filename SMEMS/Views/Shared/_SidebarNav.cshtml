@{
    var role = Context.Session.GetString("smems_user_role");

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();

    var action = ViewContext.RouteData.Values["action"]?.ToString();



    string IsActive(string ctrl, string? act = null)

    {

        bool match = controller == ctrl && (act == null || action == act);

        return match ? "active" : "";

    }
}

@if (role == "admin")

{
    <a asp-controller="Admin" asp-action="Index" class="nav-link @IsActive("Admin","Index")">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
        Dashboard
    </a>
