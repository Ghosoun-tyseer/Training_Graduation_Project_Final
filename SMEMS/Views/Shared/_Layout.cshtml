<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "SMEMS") – Smart Medical Equipment Management</title>
    <link rel="stylesheet" href="~/css/styles.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="layout">

        <!--  Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                    </svg>
                </div>
                <div class="logo-text"><strong>SMEMS</strong><small>Medical Equipment</small></div>
            </div>

            <nav class="sidebar-nav">
                @await Html.PartialAsync("_SidebarNav")
            </nav>

            <div class="sidebar-footer">
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-link">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                            <polyline points="16 17 21 12 16 7" />
                            <line x1="21" y1="12" x2="9" y2="12" />
                        </svg>
                        Logout
                    </button>
                </form>
            </div>
        </aside>

        <!--  Main-->
        <main class="main">

            <!-- Top Bar -->
            <div class="top-bar">
                <span class="top-date" id="live-clock"></span>
                <div class="top-right">
                    @{
                        var notifController = Context.Session.GetString("smems_user_role") switch

                        {

                            "admin" => "Admin",

                            "engineer" => "Engineer",

                            "staff" => "Staff",

                            _ => "Account"

                        };



                        // Get unread notification count from Session

                        var unreadCount = 0;

                        try

                        {

                            var userRole = Context.Session.GetString("smems_user_role") ?? "";

                            var userIdStr = Context.Session.GetString("smems_user_id");

                            int? userId = int.TryParse(userIdStr, out var uid) ? uid : null;

                            unreadCount = Context.Session.GetUnreadCount(userRole, userId);

                        }

                        catch { }
                    }
                    <a asp-controller="@notifController" asp-action="Notifications" class="notif-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                        </svg>
                        @if (unreadCount > 0)

                        {
                            <span class="notif-badge">@unreadCount</span>
                        }
                    </a>
                    <a asp-controller="Account" asp-action="Profile" class="user-chip">
                        <div style="text-align:right;">
                            <div class="uname">@Context.Session.GetString("smems_user_fullname")</div>
                            <div class="urole">
                                @(Context.Session.GetString("smems_user_role") switch

                                {
                                    "admin" => "Administrator",
                                    "engineer" => "Engineer",
                                    "staff" => "Medical Staff",
                                    _ => ""

                                }) / @Context.Session.GetString("smems_user_dept")
                            </div>
                        </div>
                        @{
                            var av = Context.Session.GetString("smems_user_avatar");

                            var fn = Context.Session.GetString("smems_user_fullname") ?? "?";

                            var initials = string.Join("", fn.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString() : "")).ToUpper();
                        }
                        @if (!string.IsNullOrEmpty(av))

                        {
                            <img src="@av" alt="avatar" class="avatar avatar-img" />
                        }

                        else

                        {
                            <div class="avatar">@initials</div>
                        }
                    </a>
                </div>
            </div>

            <div class="page">
                <!-- Toast -->
                @if (TempData["Success"] != null)

                {
                    <div class="toast toast-success" id="auto-toast">✓ @TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)

                {
                    <div class="toast toast-error" id="auto-toast">✗ @TempData["Error"]</div>
                }

                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/js/main.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>