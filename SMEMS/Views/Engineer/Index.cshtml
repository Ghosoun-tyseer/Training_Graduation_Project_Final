@* ─── Engineer/Index.cshtml (Dashboard) ─── *@
@{
    ViewData["Title"] = "Engineer Dashboard";
    var recentRequests = ViewBag.RecentRequests as IEnumerable<SMEMS.Models.MaintenanceRequest>
                         ?? Enumerable.Empty<SMEMS.Models.MaintenanceRequest>();
    var recentNotifs   = ViewBag.RecentNotifications as IEnumerable<SMEMS.Models.Notification>
                         ?? Enumerable.Empty<SMEMS.Models.Notification>();
    var reqsByDept     = ViewBag.RequestsByDept as IEnumerable<dynamic>
                         ?? Enumerable.Empty<dynamic>();
}

<div class="stat-row">
    <div class="stat-card">
        <div><div class="stat-label">Total Requests</div><div class="stat-value">@ViewBag.TotalAssigned</div><div class="stat-desc">Assigned to me</div></div>
        <div class="stat-icon" style="background:var(--purple-lt);color:var(--purple);">🔧</div>
    </div>
    <div class="stat-card">
        <div><div class="stat-label">Pending</div><div class="stat-value">@ViewBag.Pending</div><div class="stat-desc">Awaiting start</div></div>
        <div class="stat-icon" style="background:var(--warning-lt);color:var(--warning);">⏱</div>
    </div>
    <div class="stat-card">
        <div><div class="stat-label">In Progress</div><div class="stat-value">@ViewBag.InProgress</div><div class="stat-desc">Currently working</div></div>
        <div class="stat-icon" style="background:var(--info-lt);color:var(--info);">⚙</div>
    </div>
    <div class="stat-card">
        <div><div class="stat-label">Completed</div><div class="stat-value">@ViewBag.Completed</div><div class="stat-desc">Resolved</div></div>
        <div class="stat-icon" style="background:var(--success-lt);color:var(--success);">✓</div>
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <div class="card-title">Top Departments by Requests</div>
        @{
            var maxReq = reqsByDept.Any() ? (int)reqsByDept.Max(x => (int)x.Count) : 1;
        }
        @foreach (var d in reqsByDept)
        {
            int pct = (int)((double)(int)d.Count / maxReq * 100);
            <div class="bar-row">
                <div class="bar-lbl">@d.Dept</div>
                <div class="bar-track"><div class="bar-fill" style="width:@pct%"></div></div>
                <div class="bar-val">@d.Count</div>
            </div>
        }
    </div>

    <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div class="card-title" style="margin-bottom:0;">Recent Alerts</div>
            <a asp-action="Notifications" asp-controller="Engineer" class="btn btn-ghost btn-sm">View all</a>
        </div>
        @foreach (var n in recentNotifs)
        {
            <div style="display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border-lt);">
                <span style="font-size:16px;flex-shrink:0;">🔔</span>
                <div>
                    <div style="font-weight:600;font-size:13px;">@n.Title</div>
                    <div style="font-size:12px;color:var(--text-2);">@n.Message</div>
                    <div style="font-size:11px;color:var(--text-3);margin-top:2px;">@n.CreatedAt.ToString("M/d/yyyy, h:mm tt")</div>
                </div>
            </div>
        }
        @if (!recentNotifs.Any())
        {
            <p style="color:var(--text-3);font-size:13px;">No recent alerts.</p>
        }
    </div>
</div>

<div class="card mt-20">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <div class="card-title" style="margin-bottom:0;">Recent Maintenance Requests</div>
        <a asp-action="Maintenance" asp-controller="Engineer" class="btn btn-ghost btn-sm">View all →</a>
    </div>
    <div class="table-wrap">
        <table class="tbl">
            <thead><tr><th>Device</th><th>Issue</th><th>Dept</th><th>Risk</th><th>Status</th><th>Alt.</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var r in recentRequests)
            {
                <tr>
                    <td>
                        <div class="dev-name">@r.Device.Name</div>
                        <div class="dev-model">@r.Device.DeviceCode</div>
                    </td>
                    <td style="font-size:12px;">@r.IssueTitle</td>
                    <td>@r.Device.Department?.Name</td>
                    <td><span class="badge @(r.RiskLevel == "High" || r.RiskLevel == "Critical" ? "b-high" : r.RiskLevel == "Medium" ? "b-medium" : "b-low")">@r.RiskLevel</span></td>
                    <td><span class="badge @(r.Status == "Pending" ? "b-pending" : r.Status == "In Progress" ? "b-inprogress" : "b-completed")">@r.Status</span></td>
                        <td>@(r.HasAlternative ? Html.Raw("<span class='alt-yes-text'>Yes</span>") : Html.Raw("<span class='alt-no-text'>No</span>"))</td>
                      
                        <td class="actions-cell">
                        <a asp-action="RequestDetail" asp-controller="Engineer" asp-route-id="@r.RequestId"
                           class="ibtn ibtn-view" title="View">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                            </svg>
                        </a>
                        @if (r.Status == "Pending")
                        {
                            <form asp-action="StartMaintenance" asp-controller="Engineer" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.RequestId" />
                                <button type="submit" class="ibtn ibtn-play" title="Start">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                </button>
                            </form>
                        }
                        @if (r.Status == "In Progress")
                        {
                            <a asp-action="CompleteMaintenance" asp-controller="Engineer" asp-route-id="@r.RequestId"
                               class="ibtn ibtn-check" title="Complete">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                            </a>
                        }
                    </td>
                </tr>
            }
            @if (!recentRequests.Any())
            {
                <tr><td colspan="7" style="text-align:center;color:var(--text-3);padding:30px;">No requests assigned yet.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
