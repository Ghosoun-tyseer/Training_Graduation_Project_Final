@* ─── Staff/Index.cshtml (Dashboard) ─── *@
@{
    ViewData["Title"] = "Staff Dashboard";
    var devices    = ViewBag.Devices    as IEnumerable<SMEMS.Models.Device>
                     ?? Enumerable.Empty<SMEMS.Models.Device>();
    var myRequests = ViewBag.MyRequests as IEnumerable<SMEMS.Models.MaintenanceRequest>
                     ?? Enumerable.Empty<SMEMS.Models.MaintenanceRequest>();
}

<div class="stat-row">
    <div class="stat-card">
        <div><div class="stat-label">Total Devices</div><div class="stat-value">@ViewBag.TotalDevices</div><div class="stat-desc">In your department</div></div>
        <div class="stat-icon" style="background:var(--primary-lt);color:var(--primary);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
    </div>
    <div class="stat-card">
        <div><div class="stat-label">Available</div><div class="stat-value">@ViewBag.Available</div><div class="stat-desc">Operational devices</div></div>
        <div class="stat-icon" style="background:var(--success-lt);color:var(--success);">✓</div>
    </div>
    <div class="stat-card">
        <div><div class="stat-label">Maintenance Needed</div><div class="stat-value">@ViewBag.MaintenanceNeeded</div><div class="stat-desc">Requires attention</div></div>
        <div class="stat-icon" style="background:var(--warning-lt);color:var(--warning);">⏱</div>
    </div>
    <div class="stat-card">
        <div><div class="stat-label">Out of Service</div><div class="stat-value">@ViewBag.OutOfService</div><div class="stat-desc">Unavailable</div></div>
        <div class="stat-icon" style="background:var(--danger-lt);color:var(--danger);">⚠</div>
    </div>
</div>

<div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <div class="card-title" style="margin-bottom:0;">Department Devices</div>
        <a asp-action="SubmitRequest" asp-controller="Staff" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg> Request Maintenance
        </a>
    </div>
    <div class="table-wrap">
        <table class="tbl">
            <thead><tr><th>Device</th><th>Serial</th><th>Status</th><th>Risk</th><th>Next Maintenance</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var d in devices.Take(6))
            {
                <tr>
                    <td><div class="dev-name">@d.Name</div><div class="dev-model">@d.ModelNumber</div></td>
                    <td><code>@d.SerialNumber</code></td>
                        <td><span class="badge @(d.Status == "Operational" ? "b-operational" : d.Status == "Maintenance Needed" ? "b-needed" : d.Status == "Under Maintenance" ? "b-inprogress" : "b-outofservice")">@d.Status</span></td>
                    <td><span class="badge @(d.RiskLevel == "Low" ? "b-low" : d.RiskLevel == "Medium" ? "b-medium" : "b-high")">@d.RiskLevel</span></td>
                        <td style="font-size:12px;color:var(--text-2);">
                            @(d.NextMaintenanceDate?.ToString("MM/dd/yyyy") ?? "—") 
                        </td>
                    <td class="actions-cell">
                        
                    </td>
                        <td class="actions-cell">
                            <a href="@Url.Action("SubmitRequest", "Staff", new { deviceId = d.DeviceId })" class="ibtn ibtn-wrench" title="Request maintenance">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="pointer-events:none;">
                                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                                </svg>

                            </a>
                             <a href="@Url.Action("DeviceDetail", "Staff", new { id = d.DeviceId })" 
                           class="ibtn ibtn-view" title="View device details">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="pointer-events:none;">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        </a>

                            <a href="@Url.Action("DeviceHistory", "Staff", new { deviceId = d.DeviceId })" class="ibtn ibtn-view" title="Maintenance history">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="pointer-events:none;">
                                    <circle cx="12" cy="12" r="10" />
                                    <polyline points="12 6 12 12 16 14" />
                                </svg>
                            </a>
                        </td>
                        
                </tr>
            }
            @if (!devices.Any())
            {
                <tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:30px;">No devices in your department.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (myRequests.Any())
{
    <div class="card mt-20">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div class="card-title" style="margin-bottom:0;">My Recent Requests</div>
            <a asp-action="MyRequests" asp-controller="Staff" class="btn btn-ghost btn-sm">View all →</a>
        </div>
        @foreach (var r in myRequests)
        {
            <div class="req-card @(r.Status.ToLower().Replace(" ","-"))">
                <div class="rc-head">
                    <span class="rc-title">@r.Device.Name</span>
                    <span class="badge @(r.Status == "Pending" ? "b-pending" : r.Status == "In Progress" ? "b-inprogress" : "b-completed")">@r.Status</span>
                    <span class="badge @(r.RiskLevel == "High" || r.RiskLevel == "Critical" ? "b-high" : r.RiskLevel == "Medium" ? "b-medium" : "b-low")">@r.RiskLevel</span>
                </div>
                <div class="rc-desc">@r.IssueTitle</div>
                <div class="rc-foot">
                    <span class="rc-date">@r.RequestDate.ToString("M/d/yyyy")</span>
                    @if (r.HasAlternative)
                    {
                        <span class="rc-alt alt-yes">✓ Alternative available</span>
                    }
                    else
                    {
                        <span class="rc-alt alt-no">✗ No alternative</span>
                    }
                </div>
            </div>
        }
    </div>
}
