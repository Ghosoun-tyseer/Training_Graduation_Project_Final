@model IEnumerable<SMEMS.Models.Device>
@{
    ViewData["Title"] = "Devices";

    var departments = ViewBag.Departments as IEnumerable<SMEMS.Models.Department> ?? Enumerable.Empty<SMEMS.Models.Department>();
}

<div class="page-header-row">
    <div>
        <div class="page-title">Device Management</div>
        <div class="page-subtitle">Manage all medical equipment</div>
    </div>
    <a asp-action="AddDevice" asp-controller="Admin" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg> Add Device
    </a>
</div>

<form method="get" class="filter-bar">
    <div class="search-box">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input type="text" name="search" value="@Context.Request.Query["search"]" placeholder="Search devices..." />
    </div>
    <select name="status" class="filter-select" onchange="this.form.submit()">
        <option value="">All Status</option>
        <option value="Active" selected="@(Context.Request.Query["status"] == "Active")">Active</option>
        <option value="Maintenance Needed" selected="@(Context.Request.Query["status"] == "Maintenance Needed")">Maintenance Needed</option>
        <option value="Under Maintenance" selected="@(Context.Request.Query["status"] == "Under Maintenance")">Under Maintenance</option>
        <option value="Out Of Service" selected="@(Context.Request.Query["status"] == "Out Of Service")">Out of Service</option>
    </select>

    <select name="risk" class="filter-select" onchange="this.form.submit()">
        <option value="">All Risk</option>
        <option value="Low" selected="@(Context.Request.Query["risk"] == "Low")">Low</option>
        <option value="Medium" selected="@(Context.Request.Query["risk"] == "Medium")">Medium</option>
        <option value="High" selected="@(Context.Request.Query["risk"] == "High")">High</option>
        <option value="Critical" selected="@(Context.Request.Query["risk"] == "Critical")">Critical</option>
    </select>

    <select name="deptId" class="filter-select" onchange="this.form.submit()">
        <option value="">All Depts</option>
        @foreach (var d in departments)

        {
            <option value="@d.DepartmentId" selected="@(Context.Request.Query["deptId"] == d.DepartmentId.ToString())">
                @d.Name
            </option>
        }
    </select>
</form>

<div class="card table-wrap">
    <table class="tbl">
        <thead>
            <tr>
                <th>Code</th>
                <th>Device</th>
                <th>Department</th>
                <th>Status</th>
                <th>Risk</th>
                <th>Serial</th>
                <th>Next Maintenance</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {

                var nextMaint = d.NextMaintenanceDate?.ToString("MM/dd/yyyy") ?? "Not scheduled";
                <tr>
                    <td><code>@d.DeviceCode</code></td>
                    <td>
                        <div class="dev-name">@d.Name</div>
                        @if (!string.IsNullOrEmpty(d.ModelNumber))

                        {
                            <div class="dev-model">@d.ModelNumber</div>
                        }
                    </td>
                    <td>@d.Department?.Name</td>
                    <td>
                        <span class="badge @(d.Status == "Operational" ? "b-operational" : d.Status == "Maintenance Needed" ? "b-needed" : d.Status == "Under Maintenance" ? "b-inprogress" : "b-outofservice")">
                            @d.Status
                        </span>
                    </td>
                    <td>
                        <span class="badge @(d.RiskLevel == "Low" ? "b-low" : d.RiskLevel == "Medium" ? "b-medium" : d.RiskLevel == "High" ? "b-high" : "b-critical")">
                            @d.RiskLevel
                        </span>
                    </td>
                    <td><code style="font-size:11px;">@d.SerialNumber</code></td>
                    <td style="font-size:12px;color:var(--text-2);">@(d.NextMaintenanceDate?.ToString("MM/dd/yyyy") ?? "—")</td>
                    <td class="actions-cell">
                        <!-- Edit -->
                        <a asp-action="EditDevice" asp-controller="Admin" asp-route-id="@d.DeviceId"
                           class="ibtn ibtn-edit" title="Edit">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 20h9" />
                                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
                            </svg>
                        </a>

                        <!-- سجل صيانة الجهاز -->
                        <a asp-action="DeviceHistory" asp-controller="Admin" asp-route-deviceId="@d.DeviceId"
                           class="ibtn ibtn-view" title="Maintenance history">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10" />
                                <polyline points="12 6 12 12 16 14" />
                            </svg>
                        </a>

                        <!-- Delete -->
                        <form asp-action="DeleteDevice" asp-controller="Admin" method="post" style="display:inline;"
                              onsubmit="return confirm('Delete device @d.Name?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@d.DeviceId" />
                            <button type="submit" class="ibtn ibtn-del" title="Delete">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="3 6 5 6 21 6" />
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                </svg>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" style="text-align:center;color:var(--text-3);padding:40px;">
                        No devices found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>