@{
    ViewData["Title"] = "Admin Dashboard";
    var devicesByStatus = ViewBag.DevicesByStatus as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var recentNotifs    = ViewBag.RecentNotifications as IEnumerable<SMEMS.Models.Notification> ?? Enumerable.Empty<SMEMS.Models.Notification>();
    var reqsByDept      = ViewBag.RequestsByDept as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var devsByDept      = ViewBag.DevicesByDept as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<!-- Stat Cards -->
<div class="stat-row stat-row-3">
    <div class="stat-card">
        <div>
            <div class="stat-label">Total Devices</div>
            <div class="stat-value">@ViewBag.TotalDevices</div>
            <div class="stat-desc">Across all departments</div>
        </div>
        <div class="stat-icon" style="background:var(--primary-lt);color:var(--primary);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Total Requests</div>
            <div class="stat-value">@ViewBag.TotalRequests</div>
            <div class="stat-desc">Maintenance requests</div>
        </div>
        <div class="stat-icon" style="background:var(--purple-lt);color:var(--purple);">🔧</div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Active Users</div>
            <div class="stat-value">@ViewBag.ActiveUsers</div>
            <div class="stat-desc">System users</div>
        </div>
        <div class="stat-icon" style="background:var(--success-lt);color:var(--success);">👥</div>
    </div>
</div>

<div class="grid-2">
    <!-- Device Status Pie -->
    <div class="card">
        <div class="card-title">Device Status Distribution</div>
        <div class="pie-wrap">
            @{
                int totalDevices = devicesByStatus.Sum(x => (int)x.Count);
            }
            @if (totalDevices > 0)
            {

                double cumulativePct = 0;

                const double circumference = 157.0796;
                <svg width="140" height="140" viewBox="0 0 100 100">
                    @foreach (var s in devicesByStatus)
                    {

                        var pct = (double)(int)s.Count / totalDevices;

                        var color = (string)s.Status switch
                        {

                            "Operational" or "Active" => "#16A34A",

                            "Maintenance Needed" => "#D97706",

                            "Out of Service" => "#DC2626",

                            "Under Maintenance" => "#0891B2",

                            _ => "#94a3b8"

                        };

                        var dash = $"{pct * circumference:F4} {circumference:F4}";

                        var rot = cumulativePct * 360 - 90;
                        <circle cx="50" cy="50" r="25" fill="none"
                                stroke="@color" stroke-width="50"
                                stroke-dasharray="@dash"
                                transform="rotate(@rot.ToString("F2") 50 50)" />
                        cumulativePct += pct;
                    }
                </svg>
            }
            else
            {
                <svg width="140" height="140" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="25" fill="none" stroke="#e2e8f0" stroke-width="50" />
                </svg>
            }
            <div class="pie-legend">
                @foreach (var s in devicesByStatus)

                {
                    var color = (string)s.Status switch
                    {

                        "Operational" or "Active" => "#16A34A",

                        "Maintenance Needed" => "#D97706",

                        "Out of Service" => "#DC2626",

                        "Under Maintenance" => "#0891B2",

                        _ => "#94a3b8"
                    };
                      <div class="pie-legend-item">
                        <div class="pie-dot" style="background:@color;"></div>
                        @s.Status: @s.Count
                    </div>
                }
                @if (!devicesByStatus.Any())

                {
                    <p style="color:var(--text-3);font-size:13px;">No data.</p>
                }
            </div>
        </div>
    </div>


    <!-- Requests by Dept -->
    <div class="card">
        <div class="card-title">Top Departments by Requests</div>
        @{
            var maxReq = reqsByDept.Any() ? (int)reqsByDept.Max(x => (int)x.Count) : 1;
        }
        @foreach (var d in reqsByDept)
        {
            int pct = (int)((double)(int)d.Count / maxReq * 100);
            <div class="bar-row">
                <div class="bar-lbl">@d.Dept</div>
                <div class="bar-track"><div class="bar-fill" style="width:@pct%"></div></div>
                <div class="bar-val">@d.Count</div>
            </div>
        }
        @if (!reqsByDept.Any())
        {
            <p style="color:var(--text-3);font-size:13px;">No data yet.</p>
        }
    </div>
</div>

<!-- Devices by Department bar chart -->
<div class="card mb-20">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <div class="card-title" style="margin-bottom:0;">Devices by Department</div>
        <a asp-action="Devices" asp-controller="Admin" class="btn btn-ghost btn-sm">View Devices →</a>
    </div>
    @{
        var maxDev = devsByDept.Any() ? (int)devsByDept.Max(x => (int)x.Count) : 1;
    }
    <div style="display:flex;gap:12px;align-items:flex-end;height:120px;">
        @foreach (var d in devsByDept)
        {
            int h = (int)((double)(int)d.Count / maxDev * 100);
            <div style="display:flex;flex-direction:column;align-items:center;gap:4px;flex:1;">
                <span style="font-size:11px;font-weight:600;">@d.Count</span>
                <div style="width:100%;background:var(--primary);opacity:.85;border-radius:4px 4px 0 0;height:@(h)px;min-height:4px;"></div>
                <span style="font-size:10px;color:var(--text-3);text-align:center;">@d.Dept</span>
            </div>
        }
    </div>
</div>

<!-- Recent Notifications + Quick Actions -->
<div class="grid-2">
    <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div class="card-title" style="margin-bottom:0;">Recent Notifications</div>
            <a asp-action="Notifications" asp-controller="Admin" class="btn btn-ghost btn-sm">View all</a>
        </div>
        @foreach (var n in recentNotifs)
        {
            <div style="display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border-lt);">
                <span style="font-size:16px;flex-shrink:0;">🔔</span>
                <div style="min-width:0;flex:1;">
                    <div style="font-weight:600;font-size:13px;">@n.Title</div>
                    <div style="font-size:12px;color:var(--text-2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@n.Message</div>
                    <div style="font-size:11px;color:var(--text-3);margin-top:2px;">@n.CreatedAt.ToString("M/d/yyyy, h:mm tt")</div>
                </div>
            </div>
        }
        @if (!recentNotifs.Any())
        {
            <p style="color:var(--text-3);font-size:13px;">No notifications.</p>
        }
    </div>

    <div class="card">
        <div class="card-title">Quick Actions</div>
        <div class="quick-row" style="flex-direction:column;gap:10px;">
            <a asp-action="Reports" asp-controller="Admin" class="quick-card">
                <div class="quick-icon" style="background:var(--primary-lt);color:var(--primary);">📊</div>
                <div><div class="quick-title">Export Report</div><div class="quick-sub">Generate PDF/Excel</div></div>
            </a>
            <a asp-action="AddDevice" asp-controller="Admin" class="quick-card">
                <div class="quick-icon" style="background:var(--success-lt);color:var(--success);">📡</div>
                <div><div class="quick-title">Add Device</div><div class="quick-sub">Register new equipment</div></div>
            </a>
            <a asp-action="Register" asp-controller="Account" class="quick-card">
                <div class="quick-icon" style="background:var(--purple-lt);color:var(--purple);">👤</div>
                <div><div class="quick-title">Add User</div><div class="quick-sub">Create new account</div></div>
            </a>
        </div>
    </div>
</div>
