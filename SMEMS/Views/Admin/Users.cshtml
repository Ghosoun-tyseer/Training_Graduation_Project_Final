@model IEnumerable<UserListItemViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="page-header-row">
    <div>
        <div class="page-title">User Management</div>
        <div class="page-subtitle">Manage system users and permissions</div>
    </div>
    <a asp-action="Register" asp-controller="Account" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg> Add User
    </a>
</div>

<form method="get" class="filter-bar" style="margin-top:20px;">
    <div class="search-box">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" name="search" value="@Context.Request.Query["search"]" placeholder="Search users..." />
    </div>
    <select name="role" class="filter-select" onchange="this.form.submit()">

        @if (Context.Request.Query["role"] == "Admin")

        {
            <option value="Admin" selected>Admin</option>
        }

        else

        {
            <option value="Admin">Admin</option>
        }

        @if (Context.Request.Query["role"] == "Engineer")

        {
            <option value="Engineer" selected>Engineer</option>
        }

        else

        {
            <option value="Engineer">Engineer</option>
        }

        @if (Context.Request.Query["role"] == "Staff")

        {
            <option value="Staff" selected>Staff</option>
        }

        else

        {
            <option value="Staff">Staff</option>
        }

    </select>
</form>

<div class="card table-wrap">
    <table class="tbl">
        <thead>
            <tr><th>Name</th><th>Email</th><th>Role</th><th>Department</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var u in Model)
        {
            var initials = string.Join("", u.FullName.Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString() : "")).ToUpper();
            <tr>
                <td>
                    <div style="display:flex;align-items:center;gap:10px;">
                        @if (!string.IsNullOrEmpty(u.Avatar))
                        {
                            <img src="@u.Avatar" alt="@initials" class="avatar avatar-img"
                                 style="width:32px;height:32px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="avatar" style="width:32px;height:32px;font-size:12px;">@initials</div>
                        }
                        <span style="font-weight:500;">@u.FullName</span>
                    </div>
                </td>
                <td style="font-size:13px;color:var(--text-2);">@u.Email</td>
                <td>
                    <span class="badge @(u.Role == "Administrator" ? "b-admin" : u.Role == "Engineer" ? "b-engineer" : "b-staff")">
                        @u.Role
                    </span>
                </td>
                <td>@(u.Department ?? "—")</td>
                <td>
                    <span class="badge @(u.IsActive ? "b-active" : "b-inactive")">
                        @(u.IsActive ? "Active" : "Inactive")
                    </span>
                </td>
                <td class="actions-cell">
                    <form asp-action="ToggleUser" asp-controller="Admin" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@u.UserId" />
                        <input type="hidden" name="role" value="@u.Role" />
                        <button type="submit" class="ibtn @(u.IsActive ? "ibtn-check" : "ibtn-play")"
                                title="@(u.IsActive ? "Deactivate" : "Activate")">
                            @if (u.IsActive)
                            {
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                            }
                            else
                            {
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                            }
                        </button>
                    </form>
                    <form asp-action="DeleteUser" asp-controller="Admin" method="post" style="display:inline;"
                          onsubmit="return confirm('Delete user @u.FullName? This cannot be undone.')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@u.UserId" />
                        <input type="hidden" name="role" value="@u.Role" />
                        <button type="submit" class="ibtn ibtn-del" title="Delete">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                            </svg>
                        </button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="6" style="text-align:center;color:var(--text-3);padding:40px;">No users found.</td></tr>
        }
        </tbody>
    </table>
</div>
